{
  "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json#",
  "view": {
    "kind": "Form",
    "properties": {
      "title": "Azure Monitor Baseline Alerts Accelerator - Azure VMware Solution (AVS)",
      "steps": [
        {
          "name": "basics",
          "label": "Deployment Settings",
          "elements": [
            {
              "name": "baselineAlertsIntro",
              "type": "Microsoft.Common.InfoBox",
              "visible": true,
              "options": {
                "text": "This AMBA Accelerator for Azure VMware Solution (AVS) will automatically create alerts and action group in the selected subscription. It can be implemented in both greenfield and brownfield scenarios.",
                "style": "Info"
              }
            },
            {
              "name": "resourceScope",
              "type": "Microsoft.Common.ResourceScope",
              "kind": "Subscription",
              "instanceDetailsLabel": "AMBA-AVS Accelerator"
            },
            {
              "name": "getSubscriptionsAPI",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "subscriptions?api-version=2022-12-01"
              }
            },
            {
              "name": "getPrivateCloudsAPI",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "[format('subscriptions/{0}/providers/Microsoft.AVS/privateClouds?api-version=2025-09-01', steps('basics').resourceScope.subscription.id)]"
              }
            },
            {
              "name": "selectPrivateCloud",
              "type": "Microsoft.Common.DropDown",
              "label": "Target AVS cluster",
              "multiselect": false,
              "defaultValue": "",
              "filter": false,
              "defaultDescription": "Select an Azure VMware Solution environment",
              "toolTip": "AVS environment to be monitored.",
              "constraints": {
                "allowedValues": "[filter(map(steps('Configuration').getSubscriptionsAPI.value, (item) => parse(concat('{\"label\":\"', item.displayName, '\",\"value\":\"', item.subscriptionId, '\"}'))), (item) => equals(item.label, steps('basics').resourceScope.subscription.displayName))]",
                "required": true
              },
              "visible": true
            },
            {
              "name": "AVSAlertPrefix",
              "type": "Microsoft.Common.TextBox",
              "label": "Alert name prefix",
              "toolTip": "Provide a prefix to use for AVS alert creation.",
              "visible": "true",
              "defaultValue": "AVSAlerts",
              "constraints": {
                "required": "true",
                "validations": [
                  {
                    "regex": "^[a-zA-Z0-9][a-zA-Z0-9-_.()]{0,89}[a-zA-Z0-9]$",
                    "validationMessage": "Please provide a valid alert name prefix"
                  }
                ]
              }
            },
            {
              "name": "AVSActionGroupName",
              "type": "Microsoft.Common.TextBox",
              "label": "Action group name",
              "toolTip": "Provide a name for the action group containing the email address(es) for alert notifications.",
              "visible": "true",
              "defaultValue": "AVSAlerts",
              "constraints": {
                "required": "true",
                "validations": [
                  {
                    "regex": "^[a-zA-Z0-9][a-zA-Z0-9-_.()]{0,89}[a-zA-Z0-9]$",
                    "validationMessage": "Please provide a valid action group name"
                  }
                ]
              }
            },
            {
              "name": "AVSMonitorActionGroupEmail",
              "type": "Microsoft.Common.TextBox",
              "label": "Email addresses to be added to the action group.",
              "toolTip": "Provide the email address(es) for the action group used for notification. Use the format [\"example1@contoso.com\",\"example2@contoso.com\"].",
              "visible": true,
              "placeholder": "[\"example1@contoso.com\",\"example2@contoso.com\"]",
              "defaultValue": "",
              "constraints": {
                "required": false,
                "validations": [
                  {
                    "regex": "",
                    "validationMessage": ""
                  }
                ]
              }
            },
            {
              "name": "cuaSection",
              "type": "Microsoft.Common.Section",
              "label": "Telemetry Tracking Using Customer Usage Attribution (PID)",
              "elements": [
                {
                  "name": "cuaSettingsInfo",
                  "type": "Microsoft.Common.InfoBox",
                  "visible": true,
                  "options": {
                    "text": "Microsoft can identify the deployments of the Azure Resource Manager templates with the deployed Azure resources. Microsoft collects this information to provide the best experiences with their products and to operate their business. The telemetry is collected through customer usage attribution. The data is collected and governed by Microsoft's privacy policies, located at the trust center. Visit this link to find out more.",
                    "uri": "https://azure.github.io/azure-monitor-baseline-alerts/patterns/alz/Telemetry/",
                    "style": "Info"
                  }
                },
                {
                  "name": "telemetryOptOut",
                  "type": "Microsoft.Common.OptionsGroup",
                  "visible": true,
                  "label": "Customer Usage Selection Options",
                  "defaultValue": "Enabled",
                  "constraints": {
                    "allowedValues": [
                      {
                        "label": "Enabled",
                        "value": "No"
                      },
                      {
                        "label": "Disabled",
                        "value": "Yes"
                      }
                    ],
                    "required": true
                  }
                }
              ],
              "visible": true
            },
            {
              "name": "feedbackSection",
              "type": "Microsoft.Common.InfoBox",
              "visible": true,
              "options": {
                "text": "If you have any feedback, please use the following link: https://aka.ms/amba/issues",
                "uri": "https://aka.ms/amba/issues",
                "style": "Info"
              }
            }
          ]
        }
      ]
    },
    "outputs": {
      "kind": "Subscription",
      "subscriptionId": "[steps('basics').resourceScope.subscription.id]",
      "parameters": {
        "PrivateCloudResourceId": "[steps('Configuration').selectPrivateCloud]",
        "AlertPrefix": "[steps('basics').AVSAlertPrefix]",
        "ActionGroupName": "[steps('basics').AVSActionGroupName]",
        "ActionGroupEmail": "[steps('basics').AVSMonitorActionGroupEmail]",
        "telemetryOptOut": "[steps('basics').cuaSection.telemetryOptOut]"
      }
    }
  }
}
